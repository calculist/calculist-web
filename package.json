{
  "name": "calculist-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node esbuild.config.js",
    "build:watch": "node esbuild.config.js --watch",
    "test": "jest --runInBand",
    "test:watch": "jest --runInBand --watch"
  },
  "devDependencies": {
    "@types/backbone": "^1.4.23",
    "@types/d3": "^7.4.3",
    "@types/jquery": "^4.0.0",
    "@types/lodash": "^4.17.24",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "typescript": "^6.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/spec/javascripts/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^lodash$": "<rootDir>/vendor/assets/javascripts/lodash/lodash"
    }
  },
  "dependencies": {
    "backbone": "^1.2.3",
    "clipboard": "^1.7.1",
    "d3": "^4.13.0",
    "jquery": "^3.7.1",
    "jsondiffpatch": "^0.4.1",
    "katex": "^0.16.44",
    "lodash": "^4.17.23",
    "mark.js": "^8.11.1",
    "papaparse": "^4.6.3",
    "simple-statistics": "^7.8.9"
  }
}
